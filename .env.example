# ─────────────────────────────────────────────────────────────────────────────
# Harvesters Reporting System — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Harvesters Reporting System"

# ── Organisation ─────────────────────────────────────────────────────────────
# Used internally to scope all records. Do NOT hardcode anywhere else.
NEXT_PUBLIC_ORG_ID=harvesters-org-prod

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_NAME=hrs_token
REFRESH_COOKIE_NAME=hrs_refresh

# ── Deadlines ────────────────────────────────────────────────────────────────
# Hours after period close before report is auto-flagged late
REPORT_DEADLINE_HOURS=48
# Hours before deadline to send reminder notification
REPORT_REMINDER_HOURS=24

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_GOAL_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_DATA_ENTRY_MODE=true
# Bug-report screenshot lifecycle mode: deferred_submit (default) | preupload_draft (future mode)
NEXT_PUBLIC_BUG_REPORT_ASSET_UPLOAD_MODE=deferred_submit

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Requires a verified sender (e.g. "Harvesters <noreply@your-domain.com>")
RESEND_API_KEY=
EMAIL_FROM="Harvesters Reporting <noreply@your-domain.com>"
# Email verification / email change token TTLs (hours)
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
EMAIL_CHANGE_TOKEN_TTL_HOURS=24

# ── Cloudinary Managed Asset Lifecycle ────────────────────────────────────────
# Required for managed screenshot lifecycle and stale temp cleanup flow
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Folder structure contract: root/project/domain/year/month
CLOUDINARY_ROOT_FOLDER=harvesters-reporting
CLOUDINARY_PROJECT_ASSET_FOLDER=report-sys
# Optional token for scheduled cleanup route invocation
ASSET_CLEANUP_TOKEN=

# ── Admin Config + Quick Forms + Imports + PWA + Activation ─────────────────
# Toggle the DB-backed admin-config substrate. When false, all loader reads
# fall through to the immutable config/* defaults. Default: true.
ADMIN_CONFIG_DB_ENABLED=true
# How long the loader caches a namespace snapshot in Redis (seconds).
ADMIN_CONFIG_CACHE_TTL_SECONDS=300
# Pre-register activation token TTL (hours). Default 72.
ACTIVATION_TOKEN_TTL_HOURS=72
# Spreadsheet import file size limit in bytes. Default 10 MiB.
IMPORT_MAX_FILE_BYTES=10485760
# How long to suppress a snoozed PWA install/push banner before re-showing.
PWA_BANNER_REENGAGE_DAYS=14
# Maximum metrics included in correlation analytics views (perf cap).
ANALYTICS_CORRELATION_MAX_METRICS=12

# ── Insights + correlation algorithms ───────────────────────────────────────
# Pearson correlation requires at least this many paired samples to surface a value.
INSIGHTS_PEARSON_MIN_SAMPLES=5
# Window (in periods) for top-mover deltas.
INSIGHTS_TOP_MOVER_WINDOW_PERIODS=4
# Master kill switch for insight rendering across dashboards + analytics.
INSIGHTS_ENABLED=true

# ── Superadmin role-impersonation / preview ───────────────────────────────
# Time-to-live (minutes) for an impersonation session. Default 30.
IMPERSONATION_TTL_MINUTES=30
# Master kill switch for the impersonation feature. Default true.
IMPERSONATION_ENABLED=true
# Per-user-per-day cap for /api/email/test sends (preview-only when RESEND key missing).
RESEND_TEST_DAILY_LIMIT=50
# Toggle the DB-backed email-templates substrate. False = always use registry defaults.
EMAIL_TEMPLATES_DB_ENABLED=true

# ── Spreadsheet imports + public copy substrate (added 2026-05-05) ─────────
# Cap on the number of sheets parsed from an XLSX workbook. Beyond this, extra
# sheets are ignored (parse cost grows with sheet count).
IMPORT_XLSX_MAX_SHEETS=12
# Allowlist of accepted upload mimes for /api/imports/[id]/file (comma-separated).
IMPORT_ALLOWED_MIMES=text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel
# Toggle the DB-backed public-copy substrate. False = always use config/content.ts fallback.
PUBLIC_COPY_DB_ENABLED=true

# ── Optional Infrastructure (for production)
# REDIS_URL=  # Upstash Redis connection string (optional, used for caching and rate limiting)
# DATABASE_URL=  # Postgres connection string (production database)
